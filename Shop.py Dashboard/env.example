# ─── Postgres (Docker Compose defaults) ───────────────────────────────────────
POSTGRES_USER=pitch_user
POSTGRES_PASSWORD=pitch_pass
POSTGRES_DB=pitch_db
POSTGRES_PORT=5432

# ─── API  ─────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://pitch_user:pitch_pass@localhost:5432/pitch_db?schema=public"
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
PORT=4000
NODE_ENV=development
DEMO_MODE=true
CORS_ORIGIN=http://localhost:5173

# ─── Web  ─────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_DEMO_MODE=true
